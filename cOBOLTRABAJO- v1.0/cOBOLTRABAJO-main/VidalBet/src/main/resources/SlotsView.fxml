<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="1280.0" spacing="20.0" style="-fx-background-color: #12151B;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.SlotsController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #0E1116; -fx-padding: 0 30;">
        <Button onAction="#volverAlCasino" styleClass="sidebar-button" text="← VOLVER AL CASINO" style="-fx-text-fill: #E5C04A;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblSaldoSlots" style="-fx-text-fill: #E5C04A; -fx-font-size: 20px; -fx-font-weight: bold;" text="Saldo: 0.00 €" />
    </HBox>

    <VBox alignment="CENTER" spacing="40.0" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #1C2028; -fx-padding: 30; -fx-background-radius: 20; -fx-border-color: #E5C04A; -fx-border-width: 5; -fx-max-width: 600;">
            <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot1" text="7" styleClass="slot-text"/></VBox>
            <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot2" text="7" styleClass="slot-text"/></VBox>
            <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot3" text="7" styleClass="slot-text"/></VBox>
        </HBox>

        <HBox alignment="CENTER" spacing="50.0">
            <VBox spacing="10.0">
                <Label text="IMPORTE A JUGAR" style="-fx-text-fill: #7A808C; -fx-font-weight: bold;" />
                <TextField fx:id="txtApuesta" prefWidth="150.0" promptText="€" styleClass="bet-input" text="5" />
            </VBox>

            <Button fx:id="btnPalanca" onAction="#tirarDeLaPalanca" styleClass="lever-button" text="PULL">
                <font><Font name="System Bold" size="24.0" /></font>
            </Button>
        </HBox>
    </VBox>
</VBox>